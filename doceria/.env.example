# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).
# Em produção (Render), defina estas variáveis no dashboard de Environment.
# ─────────────────────────────────────────────────────────────────────────────

# URL de conexão com o PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
# No Render: copiado automaticamente do banco criado pelo render.yaml
DATABASE_URL=postgresql://postgres:senha@localhost:5432/doceria

# Chave secreta do Flask — use uma string longa e aleatória em produção
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-esta-chave-em-producao

# Credenciais do painel administrativo (/painel/login)
ADMIN_USER=admin
ADMIN_PASSWORD=mude-esta-senha-em-producao

# Ambiente: development ou production
# Em production, SESSION_COOKIE_SECURE=True é ativado automaticamente
FLASK_ENV=development
